tap "homebrew/bundle"

# CLI essentials
brew "git"      # Version control

# Language/runtime managers
brew "nvm"      # Node manager
brew "pyenv"    # Python manager
brew "pipx"     # Python CLI apps

# Container runtime
brew "docker"          # Docker CLI
brew "docker-compose"  # Compose CLI
brew "colima"          # Headless containers

# Applications
cask "microsoft-edge"      # Browser
cask "telegram"            # Messaging

# AI desktop tools
cask "claude"  # AI assistant

# Optional desktop container runtime.
# Use only when you want Docker's GUI instead of Colima.
# cask "docker"  # Docker Desktop

